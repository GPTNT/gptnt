{
	"$schema": "vscode://schemas/settings/folder",
	// Editor settings
	"editor.wordWrapColumn": 99,
	"editor.rulers": [99],
	"git.ignoreLimitWarning": true,
	// Python settings
	"python.defaultInterpreterPath": "${workspaceFolder}/.venv",
	"python.terminal.activateEnvInCurrentTerminal": true,
	// Python testing settings
	"python.testing.unittestEnabled": false,
	"python.testing.pytestEnabled": true,
	"python.testing.cwd": "${workspaceFolder}",
	// Formatters and linters
	"[json,yaml,jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	},
	"[python]": {
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.fixAll": "always",
			"source.organizeImports": "always"
		},
		"editor.defaultFormatter": "charliermarsh.ruff"
	},
	// Disable telemetry
	"redhat.telemetry.enabled": false,
	// Hide various files in browser (if using "Explorer Exclude" extension)
	"files.exclude": {
		"**/.git": false,
		"**/.svn": false,
		"**/.hg": false,
		"**/CVS": false,
		"**/.DS_Store": false,
		"**/Thumbs.db": false,
		"node_modules": false,
		".venv": false,
		"**/*.git{keep,ignore,attributes}": false,
		"**/{.*_cache,__pycache__}": false,
		"LICENSE": false,
		".python-version": false,
		".editorconfig": false,
		".pre-commit-config.yaml": false,
		".vscode": false,
		".github": false,
		"*mise.toml": false,
		"*.lock": false
	},
	"explorerExclude.backup": {}
}
